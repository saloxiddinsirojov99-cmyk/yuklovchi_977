# ============================================================
# yuklovchi_977 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# --- Telegram (REQUIRED) ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# --- Redis Cloud (REQUIRED — Upstash, RedisLabs, etc.) ---
REDIS_URL=redis://username:password@your-redis-host.upstash.io:6379

# --- PostgreSQL Cloud (REQUIRED — Neon, Supabase, etc.) ---
DATABASE_URL=postgresql+asyncpg://user:password@your-host.neon.tech/dbname?sslmode=require

# --- Optional Settings ---
MAX_FILE_SIZE_BYTES=2147483648
CACHE_TTL_SECONDS=604800
WORKER_CONCURRENCY=4
TELEGRAM_RATE_LIMIT_PER_SECOND=30